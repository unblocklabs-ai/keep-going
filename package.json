{
  "name": "@unblocklabs-ai/openclaw-keep-going",
  "version": "0.1.9",
  "description": "OpenClaw plugin that starts a same-session follow-up run when the validator sees unfinished work",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "https://github.com/unblocklabs-ai/keep-going.git"
  },
  "homepage": "https://github.com/unblocklabs-ai/keep-going",
  "bugs": {
    "url": "https://github.com/unblocklabs-ai/keep-going/issues"
  },
  "keywords": [
    "openclaw",
    "plugin",
    "slack",
    "agent",
    "continuation"
  ],
  "scripts": {
    "test": "node --import tsx --test tests/**/*.test.ts",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "files": [
    "index.ts",
    "src",
    "README.md",
    "openclaw.plugin.json",
    ".claude-plugin/marketplace.json"
  ],
  "devDependencies": {
    "@types/node": "^24.6.0",
    "openclaw": "2026.4.11",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3"
  },
  "openclaw": {
    "extensions": [
      "./index.ts"
    ],
    "compat": {
      "pluginApi": ">=2026.4.9",
      "minGatewayVersion": "2026.4.9"
    },
    "build": {
      "openclawVersion": "2026.4.9",
      "pluginSdkVersion": "2026.4.9"
    },
    "release": {
      "publishToClawHub": false,
      "publishToNpm": false
    }
  }
}
