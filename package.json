{
  "name": "@unblocklabs-ai/openclaw-keep-going",
  "version": "0.1.4",
  "description": "OpenClaw plugin that nudges unfinished agent turns to continue on the same Slack thread",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "https://github.com/unblocklabs-ai/keep-going.git"
  },
  "homepage": "https://github.com/unblocklabs-ai/keep-going",
  "bugs": {
    "url": "https://github.com/unblocklabs-ai/keep-going/issues"
  },
  "keywords": [
    "openclaw",
    "plugin",
    "slack",
    "agent",
    "continuation"
  ],
  "scripts": {
    "test": "node --import ../openclaw/node_modules/tsx/dist/loader.mjs --test tests/**/*.test.ts",
    "eval:validator": "node --import ../openclaw/node_modules/tsx/dist/loader.mjs ./scripts/eval-validator.ts",
    "replay:session": "node --import ../openclaw/node_modules/tsx/dist/loader.mjs ./scripts/replay-session.ts",
    "export:truth-table": "node --import ../openclaw/node_modules/tsx/dist/loader.mjs ./scripts/export-truth-table.ts",
    "label:truth-table": "node --import ../openclaw/node_modules/tsx/dist/loader.mjs ./scripts/label-truth-table.ts",
    "clean:session": "node --import ../openclaw/node_modules/tsx/dist/loader.mjs ./scripts/clean-session.ts"
  },
  "files": [
    "index.ts",
    "src",
    "plan",
    "README.md",
    "openclaw.plugin.json",
    ".claude-plugin/marketplace.json"
  ],
  "devDependencies": {
    "@openclaw/plugin-sdk": "workspace:*"
  },
  "openclaw": {
    "extensions": [
      "./index.ts"
    ],
    "compat": {
      "pluginApi": ">=2026.4.9",
      "minGatewayVersion": "2026.4.9"
    },
    "build": {
      "openclawVersion": "2026.4.9",
      "pluginSdkVersion": "2026.4.9"
    },
    "release": {
      "publishToClawHub": false,
      "publishToNpm": false
    }
  }
}
