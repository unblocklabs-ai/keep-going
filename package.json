{
  "name": "@unblocklabs/openclaw-keep-going",
  "version": "0.3.4",
  "description": "OpenClaw Slack continuation plugin that starts a same-session follow-up run when the validator sees unfinished work",
  "type": "module",
  "license": "MIT",
  "main": "./dist/index.js",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/unblocklabs-ai/keep-going.git"
  },
  "homepage": "https://github.com/unblocklabs-ai/keep-going",
  "bugs": {
    "url": "https://github.com/unblocklabs-ai/keep-going/issues"
  },
  "keywords": [
    "openclaw",
    "plugin",
    "slack",
    "agent",
    "validator",
    "continuation"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "test": "node --import tsx --test tests/**/*.test.ts",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "check:runtime": "npm run build && npm run typecheck && npm test",
    "check:inspector": "node scripts/check-inspector.mjs",
    "marketplace:sync": "node scripts/sync-marketplace-package.mjs",
    "marketplace:check": "node scripts/sync-marketplace-package.mjs --check",
    "check:install": "npm run marketplace:check && node scripts/check-install.mjs",
    "pack:check": "npm pack --dry-run",
    "preflight": "npm run check:runtime && npm run marketplace:sync && npm run check:inspector && npm run check:install && npm run pack:check && npm audit --omit=dev",
    "release": "node scripts/release.mjs",
    "release:patch": "node scripts/release.mjs patch",
    "release:minor": "node scripts/release.mjs minor",
    "release:major": "node scripts/release.mjs major"
  },
  "files": [
    "dist",
    "README.md",
    "openclaw.plugin.json",
    ".claude-plugin/marketplace.json"
  ],
  "devDependencies": {
    "@types/node": "^25.7.0",
    "@openclaw/plugin-inspector": "^0.3.10",
    "openclaw": "2026.5.3",
    "tsx": "^4.20.6",
    "typescript": "^6.0.3"
  },
  "openclaw": {
    "extensions": [
      "./dist/index.js"
    ],
    "compat": {
      "pluginApi": ">=2026.5.3",
      "minGatewayVersion": "2026.5.3"
    },
    "build": {
      "openclawVersion": "2026.5.3",
      "pluginSdkVersion": "2026.5.3"
    },
    "install": {
      "npmSpec": "@unblocklabs/openclaw-keep-going",
      "defaultChoice": "npm",
      "minHostVersion": ">=2026.5.3"
    },
    "release": {
      "publishToClawHub": false,
      "publishToNpm": true
    }
  }
}
