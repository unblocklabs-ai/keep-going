{
  "id": "keep-going",
  "name": "Keep Going",
  "version": "0.1.3",
  "description": "Post-turn continuation plugin for Slack-based OpenClaw sessions",
  "configSchema": {
    "type": "object",
    "additionalProperties": false,
    "properties": {
      "enabled": {
        "type": "boolean"
      },
      "channels": {
        "type": "array",
        "items": {
          "type": "string"
        }
      },
      "timeoutMs": {
        "type": "integer",
        "minimum": 1
      },
      "validator": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "mode": {
            "type": "string",
            "enum": ["heuristic", "llm"]
          },
          "heuristic": {
            "type": "object",
            "additionalProperties": false,
            "properties": {
              "enabled": {
                "type": "boolean"
              }
            }
          },
          "llm": {
            "type": "object",
            "additionalProperties": false,
            "properties": {
              "provider": {
                "type": "string",
                "enum": ["openai"]
              },
              "model": {
                "type": "string"
              },
              "apiKey": {
                "type": "string"
              },
              "apiKeyEnv": {
                "type": "string"
              },
              "maxMessages": {
                "type": "integer",
                "minimum": 1
              },
              "maxChars": {
                "type": "integer",
                "minimum": 1
              },
              "includeCurrentTurnOnly": {
                "type": "boolean"
              },
              "temperature": {
                "type": "number"
              },
              "timeoutMs": {
                "type": "integer",
                "minimum": 1
              }
            }
          }
        }
      }
    }
  }
}
