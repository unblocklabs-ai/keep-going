{
  "id": "keep-going",
  "name": "Keep Going",
  "version": "0.1.2",
  "description": "Post-turn continuation plugin for Slack-based OpenClaw sessions",
  "configSchema": {
    "type": "object",
    "additionalProperties": false,
    "properties": {
      "enabled": {
        "type": "boolean"
      },
      "channels": {
        "type": "array",
        "items": {
          "type": "string"
        }
      },
      "timeoutMs": {
        "type": "integer",
        "minimum": 1
      },
      "heuristic": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "enabled": {
            "type": "boolean"
          }
        }
      }
    }
  }
}
